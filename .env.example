# ============================================================
#  Packing Detector — Ortam Değişkenleri (örnek)
#  Kopyala:  cp .env.example .env   (Windows: copy .env.example .env)
#  .env ASLA git'e commit edilmez (.gitignore'da).
# ============================================================

# ---- Shopify ----
# Mağaza alan adı (myshopify.com dahil)
SHOPIFY_SHOP_URL=magazaniz.myshopify.com
# Custom App > Admin API access token (shpat_ ile başlar, sadece bir kez gösterilir)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GraphQL Admin API sürümü (YYYY-MM). Boşsa kod içindeki varsayılan kullanılır.
SHOPIFY_API_VERSION=2025-01

# ---- Kameralar ----
# config/config.yaml içindeki {user}/{pass} placeholder'larını doldurur
CAMERA_USERNAME=admin
CAMERA_PASSWORD=Kamera_Sifreniz

# ---- Lisans ----
# Vendor tarafından üretilen lisans anahtarı. Alternatif: config/license.key dosyası.
# Boş bırakılırsa ve LICENSE_ENFORCE=false ise sistem geliştirme modunda çalışır.
LICENSE_KEY=
# true = lisans zorunlu (production). false = geliştirme (lisanssız çalışır, uyarı verir).
LICENSE_ENFORCE=false

# ---- Admin Web Panel ----
# Panel HTTP sunucusunu aç/kapat
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Panel girişi (boş bırakılırsa kimlik doğrulama KAPALI — sadece güvenli LAN'da öneririz)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---- Loglama ----
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# Zaman dilimi (snapshot/log zaman damgaları)
TZ=Europe/Istanbul
